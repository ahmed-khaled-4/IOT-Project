{
  "broker": {
    "host": "hivemq",
    "port": 1883,
    "clientId": "ThingsBoard_Gateway_Campus",
    "version": 5,
    "maxMessageNumberPerWorker": 10,
    "maxNumberOfWorkers": 100,
    "sendDataOnlyOnChange": false,
    "keepAlive": 60,
    "cleanSession": true,
    "cleanStart": true,
    "sessionExpiryInterval": 0,
    "security": {
      "type": "basic",
      "username": "thingsboard",
      "password": "changeit"
    }
  },
  "mapping": [
    {
      "topicFilter": "campus/b01/+/+/telemetry",
      "subscriptionQos": 1,
      "converter": {
        "type": "json",
        "deviceInfo": {
          "deviceNameExpressionSource": "message",
          "deviceNameExpression": "${sensor_id}",
          "deviceProfileExpressionSource": "message",
          "deviceProfileExpression": "${tb_profile}"
        },
        "sendDataOnlyOnChange": false,
        "timeout": 60000,
        "attributes": [
          {
            "type": "string",
            "key": "current_version",
            "value": "${current_version}"
          }
        ],
        "timeseries": [
          {
            "type": "double",
            "key": "temperature",
            "value": "${temperature}"
          },
          {
            "type": "double",
            "key": "humidity",
            "value": "${humidity}"
          },
          {
            "type": "bool",
            "key": "occupancy",
            "value": "${occupancy}"
          },
          {
            "type": "long",
            "key": "light_level",
            "value": "${light_level}"
          },
          {
            "type": "string",
            "key": "hvac_mode",
            "value": "${hvac_mode}"
          },
          {
            "type": "long",
            "key": "lighting_dimmer",
            "value": "${lighting_dimmer}"
          }
        ]
      }
    },
    {
      "topicFilter": "campus/b01/+/+/heartbeat",
      "subscriptionQos": 1,
      "converter": {
        "type": "json",
        "deviceInfo": {
          "deviceNameExpressionSource": "message",
          "deviceNameExpression": "${sensor_id}",
          "deviceProfileExpressionSource": "message",
          "deviceProfileExpression": "${tb_profile}"
        },
        "sendDataOnlyOnChange": false,
        "timeout": 60000,
        "attributes": [],
        "timeseries": [
          {
            "type": "string",
            "key": "heartbeat_status",
            "value": "${status}"
          },
          {
            "type": "long",
            "key": "heartbeat_timestamp",
            "value": "${timestamp}"
          }
        ]
      }
    },
    {
      "topicFilter": "campus/b01/+/+/status",
      "subscriptionQos": 1,
      "converter": {
        "type": "json",
        "deviceInfo": {
          "deviceNameExpressionSource": "message",
          "deviceNameExpression": "${sensor_id}",
          "deviceProfileExpressionSource": "message",
          "deviceProfileExpression": "${tb_profile}"
        },
        "sendDataOnlyOnChange": false,
        "timeout": 60000,
        "attributes": [],
        "timeseries": [
          {
            "type": "string",
            "key": "link_state",
            "value": "${state}"
          }
        ]
      }
    },
    {
      "topicFilter": "campus/b01/+/+/attributes",
      "subscriptionQos": 1,
      "converter": {
        "type": "json",
        "deviceInfo": {
          "deviceNameExpressionSource": "message",
          "deviceNameExpression": "${sensor_id}",
          "deviceProfileExpressionSource": "message",
          "deviceProfileExpression": "${tb_profile}"
        },
        "sendDataOnlyOnChange": false,
        "timeout": 60000,
        "attributes": [
          {
            "type": "string",
            "key": "reported_hvac_mode",
            "value": "${reported_hvac_mode}"
          },
          {
            "type": "long",
            "key": "reported_lighting_dimmer",
            "value": "${reported_lighting_dimmer}"
          },
          {
            "type": "string",
            "key": "current_version",
            "value": "${current_version}"
          }
        ],
        "timeseries": []
      }
    },
    {
      "topicFilter": "campus/b01/ota/alerts",
      "subscriptionQos": 1,
      "converter": {
        "type": "json",
        "deviceInfo": {
          "deviceNameExpressionSource": "constant",
          "deviceNameExpression": "Campus-HiveMQ-Gateway",
          "deviceProfileExpressionSource": "constant",
          "deviceProfileExpression": "Campus-Gateway-MQTT"
        },
        "sendDataOnlyOnChange": false,
        "timeout": 60000,
        "attributes": [],
        "timeseries": [
          {
            "type": "bool",
            "key": "ota_tamper",
            "value": "${ota_tamper}"
          },
          {
            "type": "string",
            "key": "ota_topic",
            "value": "${ota_topic}"
          },
          {
            "type": "string",
            "key": "alert_type",
            "value": "${alert_type}"
          },
          {
            "type": "string",
            "key": "severity",
            "value": "${severity}"
          }
        ]
      }
    }
  ],
  "requestsMapping": {
    "connectRequests": [],
    "disconnectRequests": [],
    "attributeRequests": [
      {
        "topicFilter": "campus/b01/+/+/attr-req",
        "deviceInfo": {
          "deviceNameExpressionSource": "message",
          "deviceNameExpression": "${sensor_id}"
        },
        "attributeNameExpressionSource": "constant",
        "attributeNameExpression": "desired_hvac_mode,desired_lighting_dimmer,version",
        "topicExpression": "campus/b01/${fNN}/${rXXX}/attr-update",
        "valueExpression": "${attributeValue}"
      }
    ],
    "attributeUpdates": [
      {
        "deviceNameFilter": ".*",
        "attributeFilter": "desired_hvac_mode",
        "topicExpression": "campus/b01/${deviceName}/attr-update",
        "valueExpression": "{\"desired_hvac_mode\": \"${attributeValue}\"}"
      },
      {
        "deviceNameFilter": ".*",
        "attributeFilter": "desired_lighting_dimmer",
        "topicExpression": "campus/b01/${deviceName}/attr-update",
        "valueExpression": "{\"desired_lighting_dimmer\": ${attributeValue}}"
      },
      {
        "deviceNameFilter": ".*",
        "attributeFilter": "version",
        "topicExpression": "campus/b01/${deviceName}/attr-update",
        "valueExpression": "{\"version\": \"${attributeValue}\"}"
      }
    ],
    "serverSideRpc": []
  },
  "id": "7448f658-e7f1-4427-a94a-6ca6338c40cf"
}
